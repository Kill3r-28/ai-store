# Copy to secrets.toml — never commit secrets.toml

DEV_SKIP_AUTH = "false"

# Streamlit Cloud: set APP_PUBLIC_URL to your .streamlit.app URL (no trailing slash)
# APP_PUBLIC_URL = "https://nxtwave-ai-store.streamlit.app"

ALLOWED_EMAIL_DOMAINS = "nxtwave.co.in"
ADMIN_EMAILS = "you@nxtwave.co.in"
GITHUB_TOKEN = "ghp_xxxxxxxx"

# In-app Google OAuth (do NOT use [auth] / st.login — see docs/DEPLOY_OAUTH.md)
GOOGLE_CLIENT_ID = "YOUR_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET = "GOCSPX-YOUR_CLIENT_SECRET"
OAUTH_STATE_SECRET = "generate-a-long-random-string-at-least-32-chars"

# Google Console redirect URIs: http://localhost:8501/ and https://YOUR-APP.streamlit.app/
