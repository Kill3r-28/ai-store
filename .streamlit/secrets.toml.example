# Copy to secrets.toml and fill in values. Never commit secrets.toml.
#
# Streamlit Cloud: paste this into Settings → Secrets (not the repo file).
# See docs/DEPLOY_OAUTH.md for the production block.

DEV_SKIP_AUTH = "false"

# Production only (Streamlit Cloud): your app URL without a trailing slash.
# When set, redirect_uri is forced to APP_PUBLIC_URL/oauth2callback.
# APP_PUBLIC_URL = "https://nxtwave-ai-store.streamlit.app"

ALLOWED_EMAIL_DOMAINS = "nxtwave.co.in"
ADMIN_EMAILS = "you@nxtwave.co.in"
GITHUB_TOKEN = "ghp_xxxxxxxx"

# Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client IDs → Web application
# Authorized redirect URIs (both):
#   http://localhost:8501/oauth2callback
#   https://nxtwave-ai-store.streamlit.app/oauth2callback
# Authorized JavaScript origins:
#   http://localhost:8501
#   https://nxtwave-ai-store.streamlit.app
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "generate-a-long-random-string-at-least-32-chars"
client_id = "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
client_secret = "GOCSPX-YOUR_GOOGLE_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
