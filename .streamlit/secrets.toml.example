# Copy to secrets.toml and fill in values. Never commit secrets.toml.
# Streamlit Cloud: paste this same shape into Settings -> Secrets.

# Optional. Read-only GitHub token so doc fetches aren't rate-limited.
GITHUB_TOKEN = "ghp_your_token_here"

# Admin login (the "Admin login" button on the Sign-in page).
# Pick anything you like; rotate it any time without touching code.
ADMIN_USERNAME = "dev@nxtwave"
ADMIN_PASSWORD = "change-me"

# Domains allowed for the "Continue with Google" button.
ALLOWED_EMAIL_DOMAINS = "nxtwave.co.in"

# Google OAuth (Streamlit native OIDC). Skip this block if you don't want
# Google sign-in -- only the admin login button will show on the sign-in page.
#
# Authorized redirect URIs in Google Cloud Console must include:
#   http://localhost:8501/oauth2callback
#   https://<your-app>.streamlit.app/oauth2callback
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "replace-with-32-plus-random-chars"
client_id = "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
client_secret = "GOCSPX-YOUR_GOOGLE_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
