# Copy to secrets.toml and fill in values. Never commit secrets.toml.

# Local dev without Google OAuth (do not use in production)
# Shows persona picker: Teammate 1, Dev User, etc.
DEV_SKIP_AUTH = "false"

# Comma-separated email domains allowed (without @)
ALLOWED_EMAIL_DOMAINS = "nxtwave.com"

# Comma-separated admin emails for Admin page
ADMIN_EMAILS = "you@nxtwave.com"

# GitHub fine-grained PAT (read-only) for README / future_plans sync
GITHUB_TOKEN = "ghp_xxxxxxxx"

# Streamlit built-in OIDC — Google Workspace
# Create OAuth client: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8501/oauth2callback (and production URL)
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "generate-a-long-random-string"
client_id = "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_GOOGLE_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
